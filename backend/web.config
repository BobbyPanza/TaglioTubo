<?xml version="1.0" encoding="utf-8"?>
<!--
  Configurazione IIS per TaglioTubo (FastAPI/uvicorn) tramite HttpPlatformHandler.

  IIS avvia il processo Python su una porta privata (%HTTP_PLATFORM_PORT%) e gli
  inoltra tutte le richieste. La stessa app FastAPI serve sia /api sia la build
  statica del frontend (cartella backend\static), quindi tutto è same-origin.

  PREREQUISITI sul server:
    - Ruolo IIS attivo
    - Modulo "HttpPlatformHandler" installato
      (https://www.iis.net/downloads/microsoft/httpplatformhandler)
    - Python + virtualenv creato in backend\venv (vedi README, sezione Deploy IIS)
    - Application Pool in modalità "No Managed Code" e con identità che abbia
      accesso al DB FactoryTubo (Windows Auth!)

  NB: processPath è relativo alla cartella fisica del sito (= questa cartella backend).
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <httpPlatform processPath=".\venv\Scripts\python.exe"
                  arguments="-m uvicorn main:app --host 127.0.0.1 --port %HTTP_PLATFORM_PORT%"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  startupTimeLimit="120"
                  startupRetryCount="3"
                  requestTimeout="00:05:00">
      <environmentVariables>
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
